{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Metorial Documentation",
  "theme": "mint",
  "defaultColorMode": "light",
  "colors": {
    "primary": "#0099ff",
    "light": "#4eb8ff",
    "dark": "#006ab1"
  },
  "font": {
    "headings": "Inter",
    "body": "Inter",
    "code": "JetBrains Mono"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "redirects": [
    {
      "source": "/metorial-101-introduction",
      "destination": "/workforce-concepts"
    },
    {
      "source": "/metorial-101-deploying",
      "destination": "/create-portal"
    },
    {
      "source": "/metorial-101-testing",
      "destination": "/preview-portal-access"
    },
    {
      "source": "/metorial-101-monitoring",
      "destination": "/review-activity"
    },
    {
      "source": "/metorial-101-using",
      "destination": "/use-providers-with-sdks"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Start",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "index",
              "dashboard-overview",
              "workforce-concepts",
              "create-portal",
              "preview-portal-access",
              "review-activity"
            ]
          }
        ]
      },
      {
        "tab": "Workforce",
        "groups": [
          {
            "group": "Product",
            "pages": [
              "product-workforce",
              "product-portals",
              "product-magic-skills",
              "product-provider-skills"
            ]
          }
        ]
      },
      {
        "tab": "Integrations",
        "groups": [
          {
            "group": "Catalog",
            "pages": [
              "integrations-overview",
              "integrations-browsing-catalog"
            ]
          },
          {
            "group": "Setup Guides",
            "pages": [
              "integrations-api-key",
              "integrations-oauth",
              "integrations-enterprise-byo"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "API",
            "pages": [
              "api-getting-started"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk-quickstart",
              "sdk-javascript",
              "sdk-python",
              "sdk-oauth",
              "sdk-error-handling",
              "use-providers-with-sdks"
            ]
          },
          {
            "group": "Provider Runtime",
            "pages": [
              "sdk-providers-overview",
              "sdk-providers-ai-sdk",
              "sdk-providers-openai",
              "sdk-providers-anthropic",
              "sdk-providers-google",
              "sdk-providers-openai-compatible"
            ]
          },
          {
            "group": "Custom Providers",
            "pages": [
              "custom-servers-overview",
              "custom-servers-managed-getting-started",
              "custom-servers-managed-deployment",
              "custom-servers-external-connecting",
              "custom-servers-external-authentication"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Concepts",
            "pages": [
              "concepts-projects-organizations",
              "concepts-providers",
              "concepts-sessions",
              "concepts-environments",
              "concepts-monitoring"
            ]
          },
          {
            "group": "Glossary",
            "pages": [
              "glossary"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://platform.metorial.com",
          "icon": "square-terminal"
        },
        {
          "anchor": "Status",
          "href": "https://status.metorial.com",
          "icon": "circle-check"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/metorial",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@metorial.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://platform.metorial.com",
      "color": "#0099ff"
    }
  },
  "ai": {
    "enabled": true,
    "instructions": "You are a helpful assistant for Metorial documentation. Metorial connects AI agents and applications to user-authorized tools. Metorial Workforce helps teams approve integrations, publish reusable skills, connect AI clients, MCP clients, and CLIs through standard MCP URLs, and review tracing, sessions, tool calls, auth events, and errors. When answering questions, start from the user's product goal, cite the relevant documentation pages, and move API or SDK details into the developer context when appropriate. If you're unsure about something, direct users to the relevant documentation section or support at support@metorial.com."
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/metorial",
      "x": "https://x.com/MetorialAi",
      "linkedin": "https://www.linkedin.com/company/metorial"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "appearance": {
    "default": "light"
  }
}
